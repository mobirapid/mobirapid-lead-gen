# ---- Server ----
PORT=3000

# ---- Admin panel ----
# Used to log in to /admin
ADMIN_USER=admin
ADMIN_PASSWORD=change-me-now
# Secret used to sign the admin session cookie
SESSION_SECRET=please-change-this-random-string

# ---- Lead notification email (nodemailer SMTP) ----
# Where new-lead notifications are sent
LEAD_NOTIFY_TO=sachin@mobirapid.com
# SMTP credentials. Example below is for Gmail/Workspace (use an App Password).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username@mobirapid.com
SMTP_PASS=your-smtp-app-password
MAIL_FROM="Mobirapid Leads <no-reply@mobirapid.com>"

# ---- OTP via SMS ----
# Provider: "twilio" (real SMS) or "mock" (prints OTP to server console, no SMS sent)
OTP_PROVIDER=mock
# OTP length and lifetime (minutes)
OTP_TTL_MINUTES=10

# -- Twilio settings (only needed if OTP_PROVIDER=twilio) --
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
# Either a Messaging Service SID (preferred) ...
TWILIO_MESSAGING_SERVICE_SID=
# ... or a Twilio phone number to send from
TWILIO_FROM_NUMBER=+10000000000
